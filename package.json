{
  "name": "jeopardy-game",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "types"
  ],
  "scripts": {
    "dev": "concurrently -c \"cyan,magenta\" -n \"CLIENT,SERVER\" \"npm run dev -w client\" \"npm run dev -w server\"",
